# Project Kestrel v2.0 - Environment Variables
# NOTE: These API keys are OPTIONAL - the system works entirely on free tiers!
# DDGS (DuckDuckGo Search) and Nominatim require no API keys.
# Add these only if you want enhanced features or fallback capabilities.

# Optional: Foursquare Places API (100K calls/month free tier)
# Enables enhanced place discovery from Foursquare
FOURSQUARE_KEY=your_foursquare_api_key_here

# Optional: Tavily API (1K calls/month free tier)
# Used as fallback for verification when DDGS results are insufficient
TAVILY_KEY=your_tavily_api_key_here

# Optional: SerpAPI (100 calls/month free tier)
# Additional search fallback option
SERPAPI_KEY=your_serpapi_key_here
